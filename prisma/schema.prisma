// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId     String?
  organization       Organization? @relation(fields: [organizationId], references: [id])
  emissions          Emission[]
  financedEmissions  FinancedEmission[]
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users             User[]
  emissions         Emission[]
  financedEmissions FinancedEmission[]
}

model Emission {
  id             String   @id @default(cuid())
  scope          String   // Scope 1, 2, or 3
  category       String
  activity       String
  source         String
  quantity       Float
  unit           String
  emissionFactor Float
  co2e           Float
  date           DateTime
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model FinancedEmission {
  id                 String   @id @default(cuid())
  investmentName     String
  investmentType     String
  investmentAmount   Float
  currency           String
  companyName        String
  sector             String
  country            String
  attributionFactor  Float    // Percentage 0-100
  scope1             Float
  scope2             Float
  scope3             Float
  totalEmissions     Float
  calculationMethod  String
  dataQualityScore   Float    // PCAF score 1-5
  reportingYear      String
  reportingPeriod    String
  dataSource         String
  description        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId         String
  user           User     @relation(fields: [userId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}
